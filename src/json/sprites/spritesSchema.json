{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "$id": "spritesScehema",
    
    "description": "json root",
    "type": "object",
    "items:": {

        "description": "dictionary of sprites by key",
        "type": "object",
        "items": {

            "description": "sprite data",
            "type": "object",
            "properties": {
                "sprite_id": {
                    "description": "the same as sprite key",
                    "type": "string"
                },
                
                "splice": {
                    "description": "Two coordinates, the top left and the bottom right respectively.",
                    "type": "array",
                    "items": { "type": "string" }
                }
            }
        }
    }
}